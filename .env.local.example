# ============================================================
# Albion Crafting Hub — Variables de Entorno (MVP v4.0)
# Copia este archivo como .env.local y rellena los valores.
# NUNCA subas .env.local a Git.
# ============================================================

# ─── BASE DE DATOS (Vercel Postgres / Neon) ──────────────────
# Obtén esta URL desde: Vercel Dashboard → Storage → Postgres
POSTGRES_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── NEXTAUTH ────────────────────────────────────────────────
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="CAMBIA_ESTO_POR_UN_SECRET_SEGURO"
NEXTAUTH_URL="http://localhost:3000"
# En producción: NEXTAUTH_URL="https://tu-dominio.vercel.app"

# ─── CRON JOB (Vercel Cron) ──────────────────────────────────
# Genera con: openssl rand -hex 32
# Vercel lo inyecta automáticamente en el header Authorization del cron.
# También sirve para llamar al endpoint manualmente en desarrollo.
CRON_SECRET="GENERA_UN_SECRET_SEGURO_AQUI"

# ─── RESEND (Emails) ─────────────────────────────────────────
# Obtén en: https://resend.com/api-keys
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXXX"

# Dirección de envío — DEBE estar verificada en tu cuenta Resend
# Durante desarrollo puedes usar: "onboarding@resend.dev"
RESEND_FROM_EMAIL="Albion Hub <noreply@tudominio.com>"

# Email del administrador (recibe notificaciones de pagos)
ADMIN_EMAIL="tu-email@gmail.com"

# ─── UPSTASH REDIS (Rate Limiting) ───────────────────────────
# Obtén en: https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://XXXXX.upstash.io"
UPSTASH_REDIS_REST_TOKEN="XXXXXXXXXXXXXXXXXXXXXXXXX"

# ─── PAGOS WEB3 ──────────────────────────────────────────────
# Dirección de tu billetera EVM (BEP20 y BASE)
NEXT_PUBLIC_PAYMENT_ADDRESS="0xTU_WALLET_ADDRESS_AQUI"

# Precios por plan en USDT
NEXT_PUBLIC_WEEKLY_PRICE_USDT="3"
NEXT_PUBLIC_MONTHLY_PRICE_USDT="10"
NEXT_PUBLIC_YEARLY_PRICE_USDT="100"

# Precios por plan en USDC (pueden ser iguales)
NEXT_PUBLIC_WEEKLY_PRICE_USDC="3"
NEXT_PUBLIC_MONTHLY_PRICE_USDC="10"
NEXT_PUBLIC_YEARLY_PRICE_USDC="100"

# ─── CONFIGURACIÓN APP ───────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Albion Hub"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
